# Copy to .env.local and fill in. NEVER commit a file containing a real key.
# The agent loads .env.local (preferred) or .env.

# Sui network: testnet | mainnet | devnet | localnet
SUI_NETWORK=testnet

# Published Conduit package id (0x...), set after `sui client publish`.
CONDUIT_PACKAGE_ID=

# The shared Treasury object id to operate (0x...). The coin type T is read from it.
CONDUIT_TREASURY_ID=

# Agent signer. Provide ONE of these (suiprivkey... bech32 is preferred):
#   SUI_AGENT_SECRET_KEY=suiprivkey1....
#   SUI_AGENT_MNEMONIC="word word word ... (12/24 words)"
SUI_AGENT_SECRET_KEY=

# Walrus storage duration (epochs) for receipts.
WALRUS_EPOCHS=3

# Poll interval in seconds for the continuous loop.
POLL_INTERVAL_SECONDS=30
